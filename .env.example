# ============================================================
#   FindMate – Environment Variables Template
#   Copy this file to `.env` and fill in your own values.
#   NEVER commit your real `.env` file to Git!
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
# Local:  mongodb://localhost:27017/findmate
# Atlas:  mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/findmate
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/findmate

# --- JWT Secret (use a long random string in production) ---
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5000

# --- Image Upload ---
MAX_IMAGE_SIZE_MB=5

# --- Firebase (Google Sign-In) ---
# Get these from Firebase Console → Project Settings → Your apps → Web app
FIREBASE_API_KEY=YOUR_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID

# --- Admin Account (used by create-admin.js) ---
ADMIN_EMAIL=admin@findmate.com
ADMIN_PASSWORD=ChangeMe@123
ADMIN_NAME=FindMate Admin
